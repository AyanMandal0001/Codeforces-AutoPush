# Codeforces API credentials (get from https://codeforces.com/settings/api)
CF_API_KEY=your_api_key_here
CF_API_SECRET=your_api_secret_here

# Your Codeforces handle (username)
CF_HANDLE=your_handle

# GitHub Personal Access Token (needs "repo" scope)
# Get from https://github.com/settings/tokens
# Required because the script pushes to a DIFFERENT repo than where it runs
GITHUB_TOKEN=ghp_your_github_token

# Target GitHub repository where solutions will be pushed (format: username/repo-name)
GITHUB_REPO=YourUsername/YourRepo

# Subdirectory inside the target repo for Codeforces solutions
GITHUB_TARGET_DIR=CodeForces
